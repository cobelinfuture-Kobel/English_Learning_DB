  "text_pipeline": [
    "AUTHORITY_QUERY",
    "CANDIDATE_JSON_BUILD",
    "SCHEMA_VALIDATION",
    "LEVEL_VALIDATION",
    "LANGUAGE_AUTHORITY_VALIDATION",
    "SEMANTIC_VALIDATION",
    "ANSWERABILITY_VALIDATION",
    "ADMISSION_DECISION",
    "APPROVED_CANONICAL_JSON",
    "FOUR_SKILL_PROJECTION_JSON",
    "RUNTIME_CONSUMPTION",
    "EXCEL_REFERENCE_EXPORT"
