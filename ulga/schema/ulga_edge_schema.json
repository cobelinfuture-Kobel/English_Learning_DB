{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ulga/schema/ulga_edge_schema.json",
  "title": "ULGA Edge Schema",
  "contract_version": "ULGA-S2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_node_id",
    "target_node_id",
    "edge_type",
    "authority_source",
    "confidence",
    "version",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^edge:[A-Za-z0-9_.:-]+$"
    },
    "source_node_id": {
      "type": "string",
      "minLength": 1
    },
    "target_node_id": {
      "type": "string",
      "minLength": 1
    },
    "edge_type": {
      "type": "string",
      "enum": [
        "prerequisite",
        "supports",
        "belongs_to",
        "unlocks",
        "reviews",
        "contrasts_with",
        "uses",
        "contains",
        "spiral_to",
        "assesses"
      ]
    },
    "authority_source": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source_name",
        "derivation"
      ],
      "properties": {
        "source_name": {
          "type": "string",
          "minLength": 1
        },
        "source_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_record_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "derivation": {
          "type": "string",
          "enum": [
            "source_direct",
            "source_recovered",
            "rule_based",
            "manual_review",
            "derived_safe_layer",
            "planner_runtime",
            "learner_runtime",
            "scaffold"
          ]
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "value",
        "method"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "contract"
      ],
      "properties": {
        "contract": {
          "type": "string",
          "const": "ULGA-S2"
        },
        "source_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "generated_at": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
