{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ulga/learner_state/learner_state_schema.json",
  "title": "ULGA Learner State Schema",
  "contract_version": "ULGA-S9C",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_metadata",
    "node_type_enum",
    "mastery_band_enum",
    "learner_state_collection_schema"
  ],
  "properties": {
    "contract_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "contract_version",
        "schema_version",
        "purpose",
        "source_design_scan",
        "schema_only_no_builder_logic"
      ],
      "properties": {
        "contract_id": {
          "type": "string",
          "const": "ulga.learner_state"
        },
        "contract_version": {
          "type": "string",
          "const": "ULGA-S9C"
        },
        "schema_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "source_design_scan": {
          "type": "string",
          "const": "docs/ulga/ULGA_S9A_LEARNER_STATE_AUTHORITY_DESIGN_SCAN.md"
        },
        "schema_only_no_builder_logic": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "node_type_enum": {
      "type": "array",
      "minItems": 11,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "grammar",
          "vocabulary",
          "chunk",
          "sentence_pattern",
          "theme",
          "morphology",
          "reading",
          "dialogue",
          "assessment",
          "skill",
          "exercise_type"
        ]
      }
    },
    "mastery_band_enum": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "unknown",
          "seen",
          "practicing",
          "functional",
          "mastered",
          "automatic"
        ]
      }
    },
    "learner_state_collection_schema": {
      "$ref": "#/$defs/learner_state_collection_schema"
    }
  },
  "$defs": {
    "node_type": {
      "type": "string",
      "enum": [
        "grammar",
        "vocabulary",
        "chunk",
        "sentence_pattern",
        "theme",
        "morphology",
        "reading",
        "dialogue",
        "assessment",
        "skill",
        "exercise_type"
      ]
    },
    "mastery_band": {
      "type": "string",
      "enum": [
        "unknown",
        "seen",
        "practicing",
        "functional",
        "mastered",
        "automatic"
      ]
    },
    "timestamp_or_null": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "method"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_name",
        "derivation",
        "aggregation_version"
      ],
      "properties": {
        "authority_name": {
          "type": "string",
          "const": "LearnerStateAuthority"
        },
        "derivation": {
          "type": "string",
          "minLength": 1
        },
        "aggregation_version": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "learner_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "learner_id",
        "node_id",
        "node_type",
        "mastery_score",
        "mastery_band",
        "exposure_count",
        "correct_count",
        "incorrect_count",
        "last_seen_at",
        "last_success_at",
        "evidence_refs",
        "decay_adjusted_score",
        "review_due_at",
        "confidence",
        "source",
        "state_updated_at",
        "processing_idempotency_key"
      ],
      "properties": {
        "learner_id": {
          "type": "string",
          "minLength": 1
        },
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "node_type": {
          "$ref": "#/$defs/node_type"
        },
        "mastery_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "mastery_band": {
          "$ref": "#/$defs/mastery_band"
        },
        "exposure_count": {
          "type": "integer",
          "minimum": 0
        },
        "correct_count": {
          "type": "integer",
          "minimum": 0
        },
        "incorrect_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_seen_at": {
          "$ref": "#/$defs/timestamp_or_null"
        },
        "last_success_at": {
          "$ref": "#/$defs/timestamp_or_null"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "decay_adjusted_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "review_due_at": {
          "$ref": "#/$defs/timestamp_or_null"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "state_updated_at": {
          "type": "string",
          "minLength": 1
        },
        "processing_idempotency_key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "learner_state_collection_schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "learner_state_records"
      ],
      "properties": {
        "contract_version": {
          "type": "string",
          "const": "ULGA-S9C"
        },
        "learner_state_records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/learner_state_record"
          }
        }
      }
    }
  }
}
