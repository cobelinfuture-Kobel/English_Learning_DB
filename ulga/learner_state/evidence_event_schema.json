{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ulga/learner_state/evidence_event_schema.json",
  "title": "ULGA Evidence Event Schema",
  "contract_version": "ULGA-S9B",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_metadata",
    "event_type_enum",
    "node_type_enum",
    "role_enum",
    "evidence_event_collection_schema"
  ],
  "properties": {
    "contract_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "contract_version",
        "schema_version",
        "purpose",
        "source_design_scan",
        "schema_only_no_learner_state_aggregation"
      ],
      "properties": {
        "contract_id": {
          "type": "string",
          "const": "ulga.evidence_event"
        },
        "contract_version": {
          "type": "string",
          "const": "ULGA-S9B"
        },
        "schema_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "source_design_scan": {
          "type": "string",
          "const": "docs/ulga/ULGA_S9A_LEARNER_STATE_AUTHORITY_DESIGN_SCAN.md"
        },
        "schema_only_no_learner_state_aggregation": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "event_type_enum": {
      "type": "array",
      "minItems": 9,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "worksheet",
          "quiz",
          "reading",
          "dialogue",
          "speaking",
          "writing",
          "listening",
          "manual_parent_input",
          "manual_teacher_input"
        ]
      }
    },
    "node_type_enum": {
      "type": "array",
      "minItems": 11,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "grammar",
          "vocabulary",
          "chunk",
          "sentence_pattern",
          "theme",
          "morphology",
          "reading",
          "dialogue",
          "assessment",
          "skill",
          "exercise_type"
        ]
      }
    },
    "role_enum": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "primary_target",
          "supporting_context",
          "prerequisite",
          "diagnostic_signal",
          "review_signal",
          "coverage_signal"
        ]
      }
    },
    "evidence_event_collection_schema": {
      "$ref": "#/$defs/evidence_event_collection_schema"
    }
  },
  "$defs": {
    "event_type": {
      "type": "string",
      "enum": [
        "worksheet",
        "quiz",
        "reading",
        "dialogue",
        "speaking",
        "writing",
        "listening",
        "manual_parent_input",
        "manual_teacher_input"
      ]
    },
    "node_type": {
      "type": "string",
      "enum": [
        "grammar",
        "vocabulary",
        "chunk",
        "sentence_pattern",
        "theme",
        "morphology",
        "reading",
        "dialogue",
        "assessment",
        "skill",
        "exercise_type"
      ]
    },
    "node_role": {
      "type": "string",
      "enum": [
        "primary_target",
        "supporting_context",
        "prerequisite",
        "diagnostic_signal",
        "review_signal",
        "coverage_signal"
      ]
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "method"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer",
        "channel",
        "derivation"
      ],
      "properties": {
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "derivation": {
          "type": "string",
          "minLength": 1
        },
        "source_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_record_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "node_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_type",
        "role",
        "weight"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "node_type": {
          "$ref": "#/$defs/node_type"
        },
        "role": {
          "$ref": "#/$defs/node_role"
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "evidence_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "learner_id",
        "event_type",
        "timestamp",
        "node_refs",
        "score",
        "attempt_count",
        "response_time",
        "error_type",
        "confidence",
        "source",
        "processing_idempotency_key"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "learner_id": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "$ref": "#/$defs/event_type"
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        },
        "node_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/node_ref"
          }
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "attempt_count": {
          "type": "integer",
          "minimum": 1
        },
        "response_time": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "error_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "processing_idempotency_key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_event_collection_schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "events"
      ],
      "properties": {
        "contract_version": {
          "type": "string",
          "const": "ULGA-S9B"
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_event"
          }
        }
      }
    }
  }
}
