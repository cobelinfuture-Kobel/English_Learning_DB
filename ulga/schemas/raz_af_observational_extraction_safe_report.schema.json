{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ulga/schemas/raz_af_observational_extraction_safe_report.schema.json",
  "title": "RAZ A-F observational extraction text-free safe report",
  "type": "object", "additionalProperties": false,
  "required": ["task_id", "schema_version", "extractor_version", "authority_snapshot_refs", "authority_availability", "summary", "status_distributions", "coverage_distributions", "consumer_compatibility", "records_sha256", "claim_boundaries", "validation_status", "errors"],
  "properties": {
    "task_id": {"const": "RAZ-AF-S12B_FullLanguagePedagogyObservationalExtraction"}, "schema_version": {"const": "raz.af.observational_extraction.safe_report.v1"}, "extractor_version": {"const": "raz-af-full-language-pedagogy-observational-extractor.v1"},
    "authority_snapshot_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9_.:/@-]+#[0-9a-f]{64}$"}},
    "authority_availability": {"type": "object", "additionalProperties": false, "required": ["evp_vocabulary", "evp_chunks", "chunk_equivalence", "chunk_usage_class", "generator_safe_chunks", "grammar_query", "pattern_query", "theme_situation"], "properties": {"evp_vocabulary": {"enum": ["AVAILABLE", "UNAVAILABLE"]}, "evp_chunks": {"enum": ["AVAILABLE", "UNAVAILABLE"]}, "chunk_equivalence": {"enum": ["AVAILABLE", "UNAVAILABLE"]}, "chunk_usage_class": {"enum": ["AVAILABLE", "UNAVAILABLE"]}, "generator_safe_chunks": {"enum": ["AVAILABLE", "UNAVAILABLE"]}, "grammar_query": {"enum": ["AVAILABLE", "UNAVAILABLE"]}, "pattern_query": {"enum": ["AVAILABLE", "UNAVAILABLE"]}, "theme_situation": {"enum": ["AVAILABLE", "UNAVAILABLE_INVALID_JSON", "UNAVAILABLE"]}}},
    "summary": {
      "type": "object", "additionalProperties": false,
      "required": ["s12a_identities_read", "s12b_records_built", "identity_join_count", "represented_book_count", "source_mutation_count", "content_hash_drift_count", "record_hash_drift_count", "duplicate_source_ref_count", "missing_enrichment_record_count", "extra_enrichment_record_count", "payload_hash_mismatch_count", "schema_error_count", "records_with_vocabulary_scan", "records_with_chunk_scan", "records_with_pattern_scan", "records_with_situation_function_status", "records_with_discourse_status", "records_with_pedagogical_signals", "records_with_four_skill_affordance_object", "canonical_authority_write_count", "promotion_claim_count", "learner_facing_original_text_claim_count", "safe_source_text_field_count", "safe_source_payload_field_count"],
      "properties": {
        "s12a_identities_read": {"$ref": "#/$defs/count"}, "s12b_records_built": {"$ref": "#/$defs/count"}, "identity_join_count": {"$ref": "#/$defs/count"}, "represented_book_count": {"$ref": "#/$defs/count"}, "source_mutation_count": {"$ref": "#/$defs/count"}, "content_hash_drift_count": {"$ref": "#/$defs/count"}, "record_hash_drift_count": {"$ref": "#/$defs/count"}, "duplicate_source_ref_count": {"$ref": "#/$defs/count"}, "missing_enrichment_record_count": {"$ref": "#/$defs/count"}, "extra_enrichment_record_count": {"$ref": "#/$defs/count"}, "payload_hash_mismatch_count": {"$ref": "#/$defs/count"}, "schema_error_count": {"$ref": "#/$defs/count"}, "records_with_vocabulary_scan": {"$ref": "#/$defs/count"}, "records_with_chunk_scan": {"$ref": "#/$defs/count"}, "records_with_pattern_scan": {"$ref": "#/$defs/count"}, "records_with_situation_function_status": {"$ref": "#/$defs/count"}, "records_with_discourse_status": {"$ref": "#/$defs/count"}, "records_with_pedagogical_signals": {"$ref": "#/$defs/count"}, "records_with_four_skill_affordance_object": {"$ref": "#/$defs/count"}, "canonical_authority_write_count": {"$ref": "#/$defs/count"}, "promotion_claim_count": {"$ref": "#/$defs/count"}, "learner_facing_original_text_claim_count": {"$ref": "#/$defs/count"}, "safe_source_text_field_count": {"$ref": "#/$defs/count"}, "safe_source_payload_field_count": {"$ref": "#/$defs/count"}
      }
    },
    "status_distributions": {
      "type": "object", "additionalProperties": false, "required": ["vocabulary_match", "chunk_match", "pattern_mapping", "situation_classification", "discourse_shape", "semantic_pass"],
      "properties": {
        "vocabulary_match": {"$ref": "#/$defs/vocabularyCounts"}, "chunk_match": {"$ref": "#/$defs/chunkCounts"}, "pattern_mapping": {"$ref": "#/$defs/patternCounts"}, "situation_classification": {"$ref": "#/$defs/situationCounts"}, "discourse_shape": {"$ref": "#/$defs/discourseCounts"}, "semantic_pass": {"$ref": "#/$defs/semanticCounts"}
      }
    },
    "coverage_distributions": {"type": "object", "additionalProperties": false, "required": ["levels", "records_with_semantic_import"], "properties": {"levels": {"$ref": "#/$defs/count"}, "records_with_semantic_import": {"$ref": "#/$defs/count"}}},
    "consumer_compatibility": {"type": "object", "additionalProperties": false, "required": ["m04b1_source_count", "m04b1_resolvable_count", "m04b1_unresolved_count", "m04b2_source_integrity_status"], "properties": {"m04b1_source_count": {"type": "integer", "minimum": 0}, "m04b1_resolvable_count": {"type": "integer", "minimum": 0}, "m04b1_unresolved_count": {"type": "integer", "minimum": 0}, "m04b2_source_integrity_status": {"enum": ["PASS", "FAIL", "UNAVAILABLE"]}}},
    "records_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claim_boundaries": {"type": "object", "additionalProperties": false, "required": ["observational_candidate_only", "raw_source_text_included", "source_payload_copied", "canonical_authority_write_performed", "learner_facing_material_created", "source_files_rewritten"], "properties": {"observational_candidate_only": {"const": true}, "raw_source_text_included": {"const": false}, "source_payload_copied": {"const": false}, "canonical_authority_write_performed": {"const": false}, "learner_facing_material_created": {"const": false}, "source_files_rewritten": {"const": false}}},
    "validation_status": {"enum": ["PASS_LOCAL_RAZ_AF_FULL_LANGUAGE_PEDAGOGY_OBSERVATIONAL_EXTRACTION", "FAIL"]}, "errors": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "count": {"type": "integer", "minimum": 0},
    "vocabularyCounts": {"type": "object", "additionalProperties": false, "properties": {"EXACT_FORM_POS_SENSE_CANDIDATE": {"$ref": "#/$defs/count"}, "EXACT_FORM_MULTIPLE_SENSES": {"$ref": "#/$defs/count"}, "LEMMA_POS_SENSE_AMBIGUOUS": {"$ref": "#/$defs/count"}, "LEMMA_ONLY_MATCH": {"$ref": "#/$defs/count"}, "MORPHOLOGICAL_MATCH": {"$ref": "#/$defs/count"}, "FUNCTION_WORD": {"$ref": "#/$defs/count"}, "PROPER_NOUN_CANDIDATE": {"$ref": "#/$defs/count"}, "NOT_IN_EVP": {"$ref": "#/$defs/count"}, "REVIEW_REQUIRED": {"$ref": "#/$defs/count"}}},
    "chunkCounts": {"type": "object", "additionalProperties": false, "properties": {"EXACT_CANONICAL_CHUNK_MATCH": {"$ref": "#/$defs/count"}, "EQUIVALENT_CHUNK_MATCH": {"$ref": "#/$defs/count"}, "GENERATOR_SAFE_CHUNK_MATCH": {"$ref": "#/$defs/count"}, "RECURRING_OBSERVED_CHUNK_CANDIDATE": {"$ref": "#/$defs/count"}, "FREE_COMBINATION": {"$ref": "#/$defs/count"}, "REVIEW_REQUIRED": {"$ref": "#/$defs/count"}}},
    "patternCounts": {"type": "object", "additionalProperties": false, "properties": {"EXACT_CANONICAL_PATTERN_CANDIDATE": {"$ref": "#/$defs/count"}, "GRAMMAR_ALIGNED_PATTERN_CANDIDATE": {"$ref": "#/$defs/count"}, "MULTIPLE_PATTERN_MATCHES": {"$ref": "#/$defs/count"}, "UNMAPPED_RECURRING_PATTERN": {"$ref": "#/$defs/count"}, "REVIEW_REQUIRED": {"$ref": "#/$defs/count"}}},
    "situationCounts": {"type": "object", "additionalProperties": false, "properties": {"DETERMINISTIC_SIGNAL": {"$ref": "#/$defs/count"}, "AUTHORITY_ALIGNED_CANDIDATE": {"$ref": "#/$defs/count"}, "MODEL_ASSISTED_CANDIDATE": {"$ref": "#/$defs/count"}, "MULTIPLE_CANDIDATES": {"$ref": "#/$defs/count"}, "UNKNOWN_REQUIRES_REVIEW": {"$ref": "#/$defs/count"}}},
    "discourseCounts": {"type": "object", "additionalProperties": false, "properties": {"single_description": {"$ref": "#/$defs/count"}, "repeated_description": {"$ref": "#/$defs/count"}, "listing": {"$ref": "#/$defs/count"}, "sequence": {"$ref": "#/$defs/count"}, "question_answer": {"$ref": "#/$defs/count"}, "compare": {"$ref": "#/$defs/count"}, "cause_effect": {"$ref": "#/$defs/count"}, "problem_solution": {"$ref": "#/$defs/count"}, "simple_narrative": {"$ref": "#/$defs/count"}, "procedure": {"$ref": "#/$defs/count"}, "unknown": {"$ref": "#/$defs/count"}}},
    "semanticCounts": {"type": "object", "additionalProperties": false, "properties": {"NOT_SUPPLIED": {"$ref": "#/$defs/count"}, "APPLIED": {"$ref": "#/$defs/count"}}}
  }
}
