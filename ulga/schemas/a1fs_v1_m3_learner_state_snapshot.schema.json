{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "A1FS V1 M3 private learner state snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile", "sessions", "progress", "claim_boundaries"],
  "properties": {
    "profile": {
      "type": "object",
      "required": ["learner_id", "display_label", "locale", "timezone_name", "profile_state", "profile_version", "created_at", "updated_at"],
      "properties": {
        "learner_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
        "display_label": {"type": "string", "minLength": 1, "maxLength": 80},
        "profile_state": {"enum": ["ACTIVE", "INACTIVE"]},
        "profile_version": {"type": "integer", "minimum": 1}
      }
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["session_id", "learner_id", "lesson_id", "skill", "level", "session_state", "session_version", "started_at", "ended_at"],
        "properties": {
          "skill": {"enum": ["LISTENING", "SPEAKING", "READING", "WRITING"]},
          "level": {"enum": ["A1", "A1+"]},
          "session_state": {"enum": ["ACTIVE", "COMPLETED", "ABANDONED"]},
          "session_version": {"type": "integer", "minimum": 1}
        }
      }
    },
    "progress": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["learner_id", "lesson_id", "skill", "level", "progress_state", "exposure_count", "progress_version", "first_seen_at", "last_seen_at"],
        "properties": {
          "level": {"enum": ["A1", "A1+"]},
          "progress_state": {"enum": ["NOT_STARTED", "IN_PROGRESS", "PAUSED"]},
          "exposure_count": {"type": "integer", "minimum": 0},
          "progress_version": {"type": "integer", "minimum": 1}
        }
      }
    },
    "claim_boundaries": {
      "const": {"scoring_recorded": false, "mastery_recorded": false, "a2_unlocked": false}
    }
  }
}
