{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reading_v1_p2_local_feedback.schema.json",
  "title": "ReadingV1 P2 Local Feedback",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "item_id",
    "feedback_label",
    "feedback_boundary",
    "learner_state_write",
    "private_homework_only",
    "public_ready",
    "authority_status",
    "promotion_status"
  ],
  "properties": {
    "schema_version": {
      "const": "reading_v1_p2_local_feedback.v1"
    },
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "feedback_label": {
      "enum": [
        "correct",
        "incorrect",
        "needs_review",
        "not_answered"
      ]
    },
    "feedback_boundary": {
      "const": "local_private_practice_only"
    },
    "learner_state_write": {
      "const": false
    },
    "private_homework_only": {
      "const": true
    },
    "public_ready": {
      "const": false
    },
    "not_for_public_export": {
      "const": true
    },
    "not_for_commercial_distribution": {
      "const": true
    },
    "authority_status": {
      "const": "candidate_only"
    },
    "promotion_status": {
      "const": "not_promoted"
    }
  }
}
