{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/e4s_a1v1_m11b_reviewed_private_learning_unit_bank.schema.json",
  "title": "M11B Authority-Resolved Private Learning Unit Bank",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "schema_version", "private_local_only", "source_m11a_bank_sha256", "source_resolution_matrix_sha256", "reviewed_unit_count", "canonical_egp_row_count", "deferred_unit_count", "reviewed_units", "deferred_units", "reviewed_units_sha256", "claim_boundaries"],
  "properties": {
    "task_id": {"const": "E4S-A1V1-M11B_AuthorityExceptionContentRevisionAndRevalidation"},
    "schema_version": {"const": "e4s.a1v1.m11b_reviewed_private_learning_unit_bank.v1"},
    "private_local_only": {"const": true},
