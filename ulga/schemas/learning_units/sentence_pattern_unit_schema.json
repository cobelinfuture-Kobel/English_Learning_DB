{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cobelinfuture-kobel.github.io/English_Learning_DB/schemas/learning_units/sentence_pattern_unit_schema.json",
  "title": "A1/A1+ Sentence Pattern Learning Unit",
  "description": "Foundation schema contract for A1/A1+ clear-lane learning units. This is not the final complete linguistic taxonomy.",
  "type": "object",
  "required": [
    "learning_unit_id",
    "learning_unit_type",
    "schema_version",
    "cefr_level",
    "egp_cluster_refs",
    "source_refs",
    "status",
    "sentence_role_model",
    "slot_sequence",
    "transformations",
    "positive_examples",
    "negative_examples"
  ],
  "additionalProperties": false,
  "properties": {
    "learning_unit_id": {
      "type": "string",
      "minLength": 1
    },
    "learning_unit_type": {
      "type": "string",
      "const": "SENTENCE_PATTERN_NODE"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "cefr_level": {
      "type": "string",
      "enum": [
        "A1",
        "A1_PLUS"
      ]
    },
    "egp_cluster_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "promoted",
        "deprecated"
      ]
    },
    "sentence_role_model": {
      "type": "object"
    },
    "slot_sequence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "transformations": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "positive_examples": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "negative_examples": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "x_policy": {
    "task_id": "R7-M104E9_A1A1PlusLearningUnitSchemaContractFilesImplementation",
    "foundation_not_final_taxonomy": true,
    "future_extension_allowed": true,
    "deferred_lane_processing_allowed": false,
    "a2_a2plus_progression_allowed": false,
    "canonical_grammar_write_allowed": false,
    "canonical_pattern_write_allowed": false
  }
}
