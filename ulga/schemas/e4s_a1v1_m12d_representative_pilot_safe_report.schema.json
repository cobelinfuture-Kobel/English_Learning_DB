{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/e4s_a1v1_m12d_representative_pilot_safe_report.schema.json",
  "title": "M12D Representative Pilot Safe Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "schema_version", "mode", "evidence_origin", "prior_attempt_count", "batch_attempt_count", "cumulative_attempt_count", "cumulative_attempted_unit_count", "cumulative_attempted_row_count", "outcome_counts", "batch_selection", "claim_boundaries", "validation_status", "stop_reason", "next_short_step", "errors"],
  "properties": {
    "task_id": {"const": "E4S-A1V1-M12D_RepresentativePilotExpansion"},
    "schema_version": {"const": "e4s.a1v1.m12d.representative_pilot_safe_report.v1"},
    "mode": {"enum": ["PREPARE", "IMPORT"]},
    "evidence_origin": {"enum": ["REAL_LEARNER", "TEST_FIXTURE"]},
    "prior_attempt_count": {"type": "integer", "minimum": 1, "maximum": 184},
    "batch_attempt_count": {"type": "integer", "minimum": 0, "maximum": 8},
    "cumulative_attempt_count": {"type": "integer", "minimum": 1, "maximum": 184},
    "cumulative_attempted_unit_count": {"type": "integer", "minimum": 1, "maximum": 23},
    "cumulative_attempted_row_count": {"type": "integer", "minimum": 1, "maximum": 107},
    "outcome_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "batch_selection": {
      "type": "object", "additionalProperties": false,
      "required": ["batch_size", "grammar_unit_count", "canonical_egp_row_count", "skill_counts", "role_counts"],
      "properties": {
        "batch_size": {"const": 8},
        "grammar_unit_count": {"const": 4},
        "canonical_egp_row_count": {"type": "integer", "minimum": 4, "maximum": 107},
        "skill_counts": {
          "type": "object", "additionalProperties": false,
          "required": ["reading", "writing"],
          "properties": {"reading": {"const": 4}, "writing": {"const": 4}}
        },
        "role_counts": {
          "type": "object", "additionalProperties": false,
          "required": ["practice", "assessment"],
          "properties": {"practice": {"const": 4}, "assessment": {"const": 4}}
        }
      }
    },
    "claim_boundaries": {"type": "object"},
    "validation_status": {
      "enum": [
        "PASS_M12D_REPRESENTATIVE_PILOT_BATCH_READY",
        "PASS_M12D_TEST_FIXTURE_REPRESENTATIVE_BATCH_VALIDATED",
        "PASS_M12D_REAL_LEARNER_REPRESENTATIVE_BATCH_CAPTURED"
      ]
    },
    "stop_reason": {"enum": ["REAL_LEARNER_REPRESENTATIVE_BATCH_REQUIRED", "NONE"]},
    "next_short_step": {"type": "string", "minLength": 1},
    "errors": {"type": "array", "maxItems": 0}
  }
}
