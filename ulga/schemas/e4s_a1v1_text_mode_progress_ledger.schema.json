{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/e4s_a1v1_text_mode_progress_ledger.schema.json",
  "title": "E4S A1V1 Text Mode Private Progress Evidence Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "schema_version",
    "private_local_only",
    "session_bank_sha256",
    "attempt_registry_sha256",
    "session_id",
    "learner_ref",
    "attempt_count",
    "outcome_counts",
    "attempted_unit_count",
    "attempted_row_count",
    "entries",
    "entries_sha256",
    "claim_boundaries"
  ],
  "properties": {
    "task_id": {"const": "E4S-A1V1-M08_TextModeLearnerSessionAndProgressEvidenceIntegration"},
    "schema_version": {"const": "e4s.a1v1.text_mode_progress_ledger.v1"},
    "private_local_only": {"const": true},
    "session_bank_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "attempt_registry_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "session_id": {"type": "string", "minLength": 1},
    "learner_ref": {"type": "string", "minLength": 1},
    "attempt_count": {"type": "integer", "minimum": 0, "maximum": 192},
    "outcome_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["AUTO_PASS", "AUTO_FAIL", "PENDING_HUMAN_REVIEW", "HUMAN_APPROVE", "HUMAN_REJECT", "HUMAN_DEFER"],
      "properties": {
        "AUTO_PASS": {"type": "integer", "minimum": 0},
        "AUTO_FAIL": {"type": "integer", "minimum": 0},
        "PENDING_HUMAN_REVIEW": {"type": "integer", "minimum": 0},
        "HUMAN_APPROVE": {"type": "integer", "minimum": 0},
        "HUMAN_REJECT": {"type": "integer", "minimum": 0},
        "HUMAN_DEFER": {"type": "integer", "minimum": 0}
      }
    },
    "attempted_unit_count": {"type": "integer", "minimum": 0, "maximum": 24},
    "attempted_row_count": {"type": "integer", "minimum": 0, "maximum": 109},
    "entries": {
      "type": "array",
      "maxItems": 192,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "item_id",
          "shared_item_id",
          "grammar_unit_id",
          "canonical_egp_row_ids",
          "skill",
          "item_role",
          "attempt_sequence",
          "response",
          "submitted_at",
          "scoring_mode",
          "outcome",
          "score",
          "operator_review",
          "mastery_claimed"
        ],
        "properties": {
          "evidence_id": {"type": "string", "pattern": "^M08_EVIDENCE:"},
          "item_id": {"type": "string", "minLength": 1},
          "shared_item_id": {"type": "string", "minLength": 1},
          "grammar_unit_id": {"type": "string", "minLength": 1},
          "canonical_egp_row_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "skill": {"enum": ["reading", "writing"]},
          "item_role": {"enum": ["practice", "assessment"]},
          "attempt_sequence": {"type": "integer", "minimum": 1},
          "response": {
            "oneOf": [
              {"type": "string"},
              {"type": "array", "items": {"type": "string"}, "minItems": 1}
            ]
          },
          "submitted_at": {"type": "string", "format": "date-time"},
          "scoring_mode": {"enum": ["EXACT_OPTION", "EXACT_SEQUENCE", "NORMALIZED_TEXT", "FEATURE_RUBRIC"]},
          "outcome": {"enum": ["AUTO_PASS", "AUTO_FAIL", "PENDING_HUMAN_REVIEW", "HUMAN_APPROVE", "HUMAN_REJECT", "HUMAN_DEFER"]},
          "score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
          "operator_review": {"type": "object"},
          "mastery_claimed": {"const": false}
        }
      }
    },
    "entries_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claim_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "private_local_only",
        "canonical_authority_write",
        "public_delivery",
        "persistent_learner_state_write",
        "learner_mastery_claimed",
        "retention_confirmed",
        "audio_evidence_used"
      ],
      "properties": {
        "private_local_only": {"const": true},
        "canonical_authority_write": {"const": false},
        "public_delivery": {"const": false},
        "persistent_learner_state_write": {"const": false},
        "learner_mastery_claimed": {"const": false},
        "retention_confirmed": {"const": false},
        "audio_evidence_used": {"const": false}
      }
    }
  }
}
