{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/e4s_a1v1_m12_pilot_capture_manifest.schema.json",
  "title": "M12 Real Learner Pilot Capture Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "schema_version",
    "private_local_only",
    "source_hashes",
    "runtime",
    "selection",
    "attempt_registry_contract",
    "deferred_unit",
    "capture_status",
    "claim_boundaries"
  ],
  "properties": {
    "task_id": {"const": "E4S-A1V1-M12_A1A1PlusRealLearnerPilotEvidenceCapture"},
    "schema_version": {"const": "e4s.a1v1.m12_pilot_capture_manifest.v1"},
    "private_local_only": {"const": true},
    "source_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["m11d_closeout_sha256", "m11c_runtime_manifest_sha256", "m08_source_bank_sha256", "selectable_item_ids_sha256"],
      "properties": {
        "m11d_closeout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "m11c_runtime_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "m08_source_bank_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "selectable_item_ids_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_host", "default_port", "dashboard_entrypoint", "session_entrypoint", "network_submission_enabled"],
      "properties": {
        "allowed_host": {"const": "127.0.0.1"},
        "default_port": {"type": "integer", "minimum": 1024, "maximum": 65535},
        "dashboard_entrypoint": {"const": "runtime/dashboard/index.html"},
        "session_entrypoint": {"const": "runtime/authority_session/index.html"},
        "network_submission_enabled": {"const": false}
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selectable_item_count", "private_ready_unit_count", "private_ready_row_count", "reading_item_count", "writing_item_count", "practice_item_count", "assessment_item_count", "selectable_item_ids"],
      "properties": {
        "selectable_item_count": {"const": 184},
        "private_ready_unit_count": {"const": 23},
        "private_ready_row_count": {"const": 107},
        "reading_item_count": {"const": 92},
        "writing_item_count": {"const": 92},
        "practice_item_count": {"const": 138},
        "assessment_item_count": {"const": 46},
        "selectable_item_ids": {
          "type": "array",
          "minItems": 184,
          "maxItems": 184,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "attempt_registry_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "schema_version", "session_bank_sha256", "minimum_attempt_count", "maximum_attempt_count", "evidence_origin_required", "deferred_item_submission_allowed"],
      "properties": {
        "task_id": {"const": "E4S-A1V1-M08_TextModeLearnerSessionAndProgressEvidenceIntegration"},
        "schema_version": {"const": "e4s.a1v1.text_mode_attempt_registry.v1"},
        "session_bank_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "minimum_attempt_count": {"const": 1},
        "maximum_attempt_count": {"const": 184},
        "evidence_origin_required": {"const": "REAL_LEARNER"},
        "deferred_item_submission_allowed": {"const": false}
      }
    },
    "deferred_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grammar_unit_id", "excluded_item_count", "canonical_egp_row_count", "status"],
      "properties": {
        "grammar_unit_id": {"const": "GRAMMAR_WILL_FUTURE_A1"},
        "excluded_item_count": {"const": 8},
        "canonical_egp_row_count": {"const": 2},
        "status": {"const": "DEFERRED_CAMBRIDGE_FLYERS_A2_CHILD_PATH_CEILING"}
      }
    },
    "capture_status": {"const": "READY_FOR_REAL_LEARNER_SESSION"},
    "claim_boundaries": {"type": "object"}
  }
}
