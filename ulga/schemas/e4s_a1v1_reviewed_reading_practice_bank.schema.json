{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ulga/schemas/e4s_a1v1_reviewed_reading_practice_bank.schema.json",
  "title": "E4S A1V1 reviewed private Reading practice bank",
  "type": "object", "additionalProperties": false,
  "required": ["task_id", "schema_version", "artifact_type", "policy", "source_review_queue_sha256", "source_decisions_sha256", "reviewed_item_count", "reviewed_items", "reviewed_items_sha256", "claim_boundaries"],
  "properties": {
    "task_id": {"const": "E4S-A1V1-M04B3_SourceGroundedReadingCandidateReviewAndPromotion"},
    "schema_version": {"const": "e4s.a1v1.reviewed_reading_practice_bank.v1"},
    "artifact_type": {"const": "reviewed_local_reading_practice_bank"},
    "policy": {"type": "object", "additionalProperties": false, "required": ["private_local_only", "must_not_be_committed", "canonical_authority_promotion"], "properties": {"private_local_only": {"const": true}, "must_not_be_committed": {"const": true}, "canonical_authority_promotion": {"const": false}}},
    "source_review_queue_sha256": {"$ref": "#/$defs/sha256"},
    "source_decisions_sha256": {"$ref": "#/$defs/sha256"},
    "reviewed_item_count": {"type": "integer", "minimum": 0, "maximum": 281},
    "reviewed_items": {"type": "array", "maxItems": 281, "items": {"$ref": "#/$defs/item"}},
    "reviewed_items_sha256": {"$ref": "#/$defs/sha256"},
    "claim_boundaries": {"type": "object"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "item": {
      "type": "object", "additionalProperties": false,
      "required": ["reviewed_item_id", "status", "selection_id", "source_unit_ref", "source_integrity", "original_candidate_id", "question_type", "final_private_prompt", "final_private_answer_model", "accepted_answers", "source_sentence_ids", "reviewer_id", "decision_timestamp", "decision_record_sha256", "m04b2_candidate_sha256", "s12d_observational_binding_sha256", "local_only_policy", "canonical_authority_promotion"],
      "properties": {
        "reviewed_item_id": {"type": "string", "pattern": "^M04B3_ITEM_[0-9A-F]{20}$"},
        "status": {"const": "REVIEWED_LOCAL_PRACTICE_ITEM"},
        "selection_id": {"type": "string"}, "source_unit_ref": {"type": "string"},
        "source_integrity": {"type": "object"}, "original_candidate_id": {"type": "string"},
        "question_type": {"enum": ["true_false", "cloze_vocabulary", "sentence_ordering", "literal_who", "literal_what", "literal_where"]},
        "final_private_prompt": {"type": "string", "minLength": 1}, "final_private_answer_model": {"type": "object", "minProperties": 1},
        "accepted_answers": {"type": "array"}, "source_sentence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "reviewer_id": {"type": "string", "minLength": 1}, "decision_timestamp": {"type": "string", "minLength": 1},
        "decision_record_sha256": {"$ref": "#/$defs/sha256"}, "m04b2_candidate_sha256": {"$ref": "#/$defs/sha256"},
        "s12d_observational_binding_sha256": {"$ref": "#/$defs/sha256"},
        "local_only_policy": {"const": true}, "canonical_authority_promotion": {"const": false}
      }
    }
  }
}
