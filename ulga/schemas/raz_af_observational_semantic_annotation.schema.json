{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ulga/schemas/raz_af_observational_semantic_annotation.schema.json",
  "title": "Local-only RAZ observational semantic annotation import",
  "type": "object", "additionalProperties": false,
  "required": ["source_unit_ref", "source_record_sha256", "source_content_sha256", "annotation_version", "confidence", "review_status", "annotations"],
  "properties": {
    "source_unit_ref": {"type": "string", "pattern": "^RAZ_[A-F]_[A-Za-z0-9_-]+_P[0-9]+$"}, "source_record_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "source_content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "annotation_version": {"const": "raz.af.observational_semantic_annotation.v1"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "review_status": {"enum": ["REVIEW_REQUIRED", "HUMAN_REVIEWED"]},
    "annotations": {"type": "object", "additionalProperties": false, "minProperties": 1, "properties": {"evp_sense_candidate_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^vocabulary:[A-Za-z0-9_:'-]+$"}}, "micro_situation_candidates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"}}, "communicative_function_candidates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"}}, "discourse_shape": {"enum": ["single_description", "repeated_description", "listing", "sequence", "question_answer", "compare", "cause_effect", "problem_solution", "simple_narrative", "procedure", "unknown"]}, "higher_level_affordance_labels": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["abstract_sentence_frame", "guided_retelling", "listen_and_order", "listen_and_repeat", "literal_what", "model_then_guided", "picture_description", "sentence_expansion", "sentence_ordering", "short_retelling"]}}}}
  }
}
