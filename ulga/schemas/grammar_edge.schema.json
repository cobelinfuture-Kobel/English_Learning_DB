{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cobelinfuture-Kobel/English_Learning_DB/ulga/schemas/grammar_edge.schema.json",
  "title": "GrammarSkillTree Grammar Dependency Edge",
  "description": "Canonical schema for one GrammarSkillTree grammar edge. R5-M2 implements the edge contract only; seeded edges, graph generators, validators, learner gates, and A1-B2 expansion are later R5/R6 milestones.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edge_id",
    "source",
    "target",
    "relation",
    "direction",
    "authority_status",
    "confidence",
    "source_evidence",
    "traceability"
  ],
  "properties": {
    "edge_id": {
      "type": "string",
      "pattern": "^GEDGE_[0-9]{6}$",
      "description": "Stable canonical ID for this grammar dependency edge."
    },
    "source": {
      "type": "string",
      "pattern": "^GRAMMAR_[A-Z0-9_]+$",
      "description": "Source grammar node ID. For REQUIRES, source is the unlocked or dependent node."
    },
    "target": {
      "type": "string",
      "pattern": "^GRAMMAR_[A-Z0-9_]+$",
      "description": "Target grammar node ID. For REQUIRES, target is the prerequisite node."
    },
    "relation": {
      "type": "string",
      "enum": [
        "REQUIRES",
        "PRECEDES",
        "REINFORCES",
        "CONTRASTS_WITH",
        "CONFUSABLE_WITH"
      ],
      "description": "Grammar edge relation type from the R4-M3 contract."
    },
    "direction": {
      "type": "string",
      "enum": [
        "directed",
        "bidirectional"
      ],
      "description": "REQUIRES, PRECEDES, and REINFORCES are directed. CONTRASTS_WITH and CONFUSABLE_WITH may be bidirectional when deliberately modeled that way."
    },
    "authority_status": {
      "type": "string",
      "enum": [
        "candidate",
        "accepted",
        "deprecated",
        "blocked"
      ],
      "description": "Promotion status inside the internal GrammarSkillTree edge authority."
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "operator_review_required"
      ],
      "description": "Confidence in the edge relation. AI-suggested or weakly evidenced edges must remain candidate/operator_review_required."
    },
    "rationale": {
      "type": "string",
      "default": "",
      "description": "Short explanation for why this edge exists."
    },
    "stage_scope": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "applies_from_stage": {
          "$ref": "#/$defs/stage"
        },
        "applies_through_stage": {
          "$ref": "#/$defs/stage"
        },
        "blocked_stages": {
          "type": "array",
          "uniqueItems": true,
          "default": [],
          "items": {
            "$ref": "#/$defs/stage"
          }
        },
        "notes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Optional stage applicability boundaries for the edge."
    },
    "order_table_effect": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "affects_order": {
          "type": "boolean",
          "default": true
        },
        "affects_unlock": {
          "type": "boolean",
          "default": false
        },
        "affects_recycle": {
          "type": "boolean",
          "default": false
        },
        "affects_confusion_warning": {
          "type": "boolean",
          "default": false
        }
      },
      "description": "Explicitly describes how later order-table and validator logic may use this edge."
    },
    "learner_gate_policy": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "gate_relevant": {
          "type": "boolean",
          "default": false
        },
        "minimum_source_mastery": {
          "type": "string",
          "enum": [
            "M0",
            "M1",
            "M2",
            "M3",
            "M4",
            "M5"
          ]
        },
        "minimum_target_mastery": {
          "type": "string",
          "enum": [
            "M0",
            "M1",
            "M2",
            "M3",
            "M4",
            "M5"
          ]
        },
        "notes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Optional hints for later learner next-step gate implementation. This schema does not write learner state."
    },
    "ai_edge_policy": {
      "type": "object",
      "additionalProperties": false,
      "default": {
        "ai_may_suggest": true,
        "ai_may_promote": false,
        "operator_review_required": true
      },
      "properties": {
        "ai_may_suggest": {
          "type": "boolean"
        },
        "ai_may_promote": {
          "type": "boolean"
        },
        "operator_review_required": {
          "type": "boolean",
          "default": true
        }
      },
      "description": "Guardrail for AI-suggested grammar edge candidates."
    },
    "source_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_evidence"
      },
      "description": "Traceable evidence supporting this edge relation."
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_by_task",
        "generated_content",
        "learner_state_write"
      ],
      "properties": {
        "created_by_task": {
          "type": "string",
          "pattern": "^R[0-9]+-M[0-9]+.*$"
        },
        "generated_content": {
          "type": "boolean",
          "const": false
        },
        "learner_state_write": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Task and safety traceability for this edge record."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "relation": {
            "enum": [
              "REQUIRES",
              "PRECEDES",
              "REINFORCES"
            ]
          }
        },
        "required": [
          "relation"
        ]
      },
      "then": {
        "properties": {
          "direction": {
            "const": "directed"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "relation": {
            "enum": [
              "CONTRASTS_WITH",
              "CONFUSABLE_WITH"
            ]
          }
        },
        "required": [
          "relation"
        ]
      },
      "then": {
        "properties": {
          "order_table_effect": {
            "properties": {
              "affects_confusion_warning": {
                "const": true
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "stage": {
      "type": "string",
      "enum": [
        "A1",
        "A1_PLUS",
        "A2",
        "A2_PLUS",
        "B1",
        "B1_PLUS",
        "B2"
      ]
    },
    "source_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_role",
        "allowed_use",
        "confidence"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_role": {
          "type": "string",
          "enum": [
            "authority_source",
            "normalized_authority_artifact",
            "candidate_evidence",
            "operator_design_contract"
          ]
        },
        "source_ref": {
          "type": "string",
          "default": ""
        },
        "allowed_use": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "dependency_relation_evidence",
              "order_constraint_reference",
              "recycle_relation_reference",
              "contrast_warning_reference",
              "validation_reference"
            ]
          }
        },
        "blocked_use": {
          "type": "array",
          "default": [],
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "learner_state_write",
              "learner_facing_full_text",
              "automatic_promotion",
              "standalone_teaching_order"
            ]
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "operator_review_required"
          ]
        },
        "notes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
