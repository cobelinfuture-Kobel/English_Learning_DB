{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/e4s_a1v1_private_runtime_manifest.schema.json",
  "title": "E4S A1V1 Private Learning Runtime Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "schema_version",
    "runtime_id",
    "scope",
    "bind_policy",
    "source_hashes",
    "text_mode_runtime",
    "skill_runtime_states",
    "dashboard",
    "health_contract",
    "claim_boundaries",
    "runtime_status",
    "next_short_step"
  ],
  "properties": {
    "task_id": {"const": "E4S-A1V1-M09_A1A1PlusPrivateLearningRuntimeAcceptanceAndCloseout"},
    "schema_version": {"const": "e4s.a1v1.private_learning_runtime_manifest.v1"},
    "runtime_id": {"const": "e4s-a1v1-private-local-runtime"},
    "scope": {"const": "A1_A1_PLUS_ONLY"},
    "bind_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_host", "default_port", "network_submission_enabled", "external_network_dependency"],
      "properties": {
        "allowed_host": {"const": "127.0.0.1"},
        "default_port": {"type": "integer", "minimum": 1024, "maximum": 65535},
        "network_submission_enabled": {"const": false},
        "external_network_dependency": {"const": false}
      }
    },
    "source_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["m07_closeout_sha256", "m08_closeout_sha256", "text_mode_safe_report_sha256", "text_mode_validation_sha256"],
      "properties": {
        "m07_closeout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "m08_closeout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "text_mode_safe_report_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "text_mode_validation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "text_mode_runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available_items", "reading_items", "writing_items", "practice_items", "assessment_items", "grammar_units", "canonical_egp_rows", "zero_evidence_state", "session_entrypoint"],
      "properties": {
        "available_items": {"const": 192},
        "reading_items": {"const": 96},
        "writing_items": {"const": 96},
        "practice_items": {"const": 144},
        "assessment_items": {"const": 48},
        "grammar_units": {"const": 24},
        "canonical_egp_rows": {"const": 109},
        "zero_evidence_state": {"const": "PASS_AWAITING_TEXT_MODE_LEARNER_ATTEMPTS"},
        "session_entrypoint": {"const": "text_mode/local_session/index.html"}
      }
    },
    "skill_runtime_states": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reading", "writing", "listening", "speaking"],
      "properties": {
        "reading": {"type": "object"},
        "writing": {"type": "object"},
        "listening": {"type": "object"},
        "speaking": {"type": "object"}
      }
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entrypoint", "text_session_link", "contains_private_answers", "contains_learner_responses", "recording_controls_exposed"],
      "properties": {
        "entrypoint": {"const": "dashboard/index.html"},
        "text_session_link": {"const": "../text_mode/local_session/index.html"},
        "contains_private_answers": {"const": false},
        "contains_learner_responses": {"const": false},
        "recording_controls_exposed": {"const": false}
      }
    },
    "health_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_files", "checks", "health_status"],
      "properties": {
        "required_files": {"type": "array", "minItems": 7, "items": {"type": "string"}, "uniqueItems": true},
        "checks": {"type": "array", "minItems": 8, "items": {"type": "string"}, "uniqueItems": true},
        "health_status": {"const": "PASS_PRIVATE_RUNTIME_READY"}
      }
    },
    "claim_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "private_local_only",
        "production_runtime_enabled",
        "public_delivery_enabled",
        "canonical_authority_write",
        "persistent_learner_state_service_enabled",
        "actual_learner_evidence_complete",
        "learner_mastery_claimed",
        "retention_confirmed",
        "new_audio_processing_performed",
        "recording_enabled",
        "a2_a2plus_in_scope"
      ],
      "properties": {
        "private_local_only": {"const": true},
        "production_runtime_enabled": {"const": false},
        "public_delivery_enabled": {"const": false},
        "canonical_authority_write": {"const": false},
        "persistent_learner_state_service_enabled": {"const": false},
        "actual_learner_evidence_complete": {"const": false},
        "learner_mastery_claimed": {"const": false},
        "retention_confirmed": {"const": false},
        "new_audio_processing_performed": {"const": false},
        "recording_enabled": {"const": false},
        "a2_a2plus_in_scope": {"const": false}
      }
    },
    "runtime_status": {"const": "PASS_PRIVATE_RUNTIME_READY"},
    "next_short_step": {"const": "E4S-A1V1-M10_A1A1PlusCoverageRecheckAndBacklogClosure_NoNewDesignDocs"}
  }
}
