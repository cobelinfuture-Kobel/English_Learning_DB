{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ulga/schemas/raz_af_observational_companion_identity_record.schema.json",
  "title": "RAZ A-F Observational Companion Identity Record",
  "description": "Closed, text-free identity contract for a private observational companion to one enriched RAZ page unit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observational_record_id",
    "source_unit_ref",
    "source_level",
    "source_book_id",
    "source_page_number",
    "source_record_sha256",
    "source_content_sha256",
    "enrichment_schema_version",
    "extractor_version",
    "authority_snapshot_refs",
    "enrichment_payload_sha256",
    "source_role",
    "authority_import_allowed",
    "learner_facing_original_text_allowed",
    "promotion_status"
  ],
  "properties": {
    "observational_record_id": {
      "type": "string",
      "pattern": "^RAZ_AF_OBS_V1__RAZ_[A-F]_[A-Za-z0-9_-]+_P[0-9]+$",
      "maxLength": 192
    },
    "source_unit_ref": {
      "type": "string",
      "pattern": "^RAZ_[A-F]_[A-Za-z0-9_-]+_P[0-9]+$",
      "maxLength": 160
    },
    "source_level": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E", "F"]
    },
    "source_book_id": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "maxLength": 64
    },
    "source_page_number": {
      "type": "integer",
      "minimum": 1
    },
    "source_record_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "source_content_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "enrichment_schema_version": {
      "const": "raz.af.observational_companion.v1"
    },
    "extractor_version": {
      "const": "raz-af-observational-source-integrity-adapter.v1"
    },
    "authority_snapshot_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_.:/@-]+$",
        "maxLength": 512
      }
    },
    "enrichment_payload_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "source_role": {
      "const": "observational_reference"
    },
    "authority_import_allowed": {
      "const": false
    },
    "learner_facing_original_text_allowed": {
      "const": false
    },
    "promotion_status": {
      "const": "not_promoted"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
