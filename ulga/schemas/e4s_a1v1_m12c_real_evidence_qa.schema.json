{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/e4s_a1v1_m12c_real_evidence_qa.schema.json",
  "title": "M12C Real Learner Pilot Evidence QA",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "schema_version", "mode", "evidence_origin", "source_hashes", "evidence_summary", "coverage_progress", "quality_gate", "iteration_queue", "claim_boundaries", "validation_status", "stop_reason", "next_short_step", "errors"],
  "properties": {
    "task_id": {"const": "E4S-A1V1-M12C_RealLearnerPilotEvidenceQAAndIteration"},
    "schema_version": {"const": "e4s.a1v1.m12c.real_evidence_qa.v1"},
    "mode": {"const": "EVIDENCE_QA_AND_ITERATION"},
    "evidence_origin": {"enum": ["REAL_LEARNER", "TEST_FIXTURE"]},
    "source_hashes": {"type": "object", "minProperties": 4, "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "evidence_summary": {
      "type": "object", "additionalProperties": false,
      "required": ["attempt_count", "attempted_unit_count", "attempted_row_count", "skill_attempt_counts", "role_attempt_counts", "outcome_counts", "pending_human_review_count", "auto_fail_count", "auto_pass_count"],
      "properties": {
        "attempt_count": {"type": "integer", "minimum": 1, "maximum": 184},
        "attempted_unit_count": {"type": "integer", "minimum": 1, "maximum": 23},
        "attempted_row_count": {"type": "integer", "minimum": 1, "maximum": 107},
        "skill_attempt_counts": {"type": "object", "additionalProperties": false, "required": ["reading", "writing"], "properties": {"reading": {"type": "integer", "minimum": 0}, "writing": {"type": "integer", "minimum": 0}}},
        "role_attempt_counts": {"type": "object", "additionalProperties": false, "required": ["practice", "assessment"], "properties": {"practice": {"type": "integer", "minimum": 0}, "assessment": {"type": "integer", "minimum": 0}}},
        "outcome_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "pending_human_review_count": {"type": "integer", "minimum": 0},
        "auto_fail_count": {"type": "integer", "minimum": 0},
        "auto_pass_count": {"type": "integer", "minimum": 0}
      }
    },
    "coverage_progress": {
      "type": "object", "additionalProperties": false,
      "required": ["selectable_items", "private_ready_units", "private_ready_rows", "attempted_item_percent", "attempted_unit_percent", "attempted_row_percent", "pilot_completed"],
      "properties": {
        "selectable_items": {"const": 184},
        "private_ready_units": {"const": 23},
        "private_ready_rows": {"const": 107},
        "attempted_item_percent": {"type": "number", "minimum": 0, "maximum": 100},
        "attempted_unit_percent": {"type": "number", "minimum": 0, "maximum": 100},
        "attempted_row_percent": {"type": "number", "minimum": 0, "maximum": 100},
        "pilot_completed": {"const": false}
      }
    },
    "quality_gate": {
      "type": "object", "additionalProperties": false,
      "required": ["state", "human_review_required", "remediation_required", "deterministic_evidence_valid"],
      "properties": {
        "state": {"enum": ["PASS_CONTINUE_EXPANSION", "PASS_HUMAN_REVIEW_REQUIRED", "PASS_REMEDIATION_AND_EXPANSION_REQUIRED"]},
        "human_review_required": {"type": "boolean"},
        "remediation_required": {"type": "boolean"},
        "deterministic_evidence_valid": {"const": true}
      }
    },
    "iteration_queue": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_count", "maximum_batch_size", "items"],
      "properties": {
        "candidate_count": {"type": "integer", "minimum": 0, "maximum": 8},
        "maximum_batch_size": {"const": 8},
        "items": {
          "type": "array", "maxItems": 8,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["item_id", "grammar_unit_id", "canonical_egp_row_ids", "internal_stage", "skill", "item_role", "evidence_dimension", "task_type", "reason_code"],
            "properties": {
              "item_id": {"type": "string", "minLength": 1},
              "grammar_unit_id": {"type": "string", "minLength": 1},
              "canonical_egp_row_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
              "internal_stage": {"type": "string", "minLength": 1},
              "skill": {"enum": ["reading", "writing"]},
              "item_role": {"enum": ["practice", "assessment"]},
              "evidence_dimension": {"type": "string", "minLength": 1},
              "task_type": {"type": "string", "minLength": 1},
              "reason_code": {"enum": ["AUTO_FAIL_REMEDIATION", "UNATTEMPTED_UNIT_COVERAGE", "SKILL_ROLE_BALANCE"]}
            }
          }
        }
      }
    },
    "claim_boundaries": {"type": "object"},
    "validation_status": {"enum": ["PASS_M12C_REAL_LEARNER_PILOT_EVIDENCE_QA_COMPLETE", "PASS_M12C_TEST_FIXTURE_QA_VALIDATED"]},
    "stop_reason": {"enum": ["NONE", "HUMAN_REVIEW_DECISIONS_REQUIRED"]},
    "next_short_step": {"enum": ["E4S-A1V1-M12C1_HumanReviewDecisionMaterialization", "E4S-A1V1-M12D_RepresentativePilotExpansion"]},
    "errors": {"type": "array", "maxItems": 0}
  }
}
