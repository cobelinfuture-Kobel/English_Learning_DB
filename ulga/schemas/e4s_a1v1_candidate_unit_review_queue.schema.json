{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/e4s_a1v1_candidate_unit_review_queue.schema.json",
  "title": "E4S A1V1 Candidate Unit Review Queue",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "schema_version", "private_local_only", "source_candidate_sha256", "review_entry_count", "review_entries", "review_entries_sha256", "claim_boundaries"],
  "properties": {
    "task_id": {"const": "E4S-A1V1-M11_A1A1PlusCandidateContentReviewAndPrivatePromotion"},
    "schema_version": {"const": "e4s.a1v1.candidate_unit_review_queue.v1"},
    "private_local_only": {"const": true},
    "source_candidate_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "review_entry_count": {"const": 24},
    "review_entries": {
      "type": "array",
      "minItems": 24,
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["review_entry_id", "grammar_unit_id", "internal_stage", "canonical_egp_row_ids", "candidate_payload_sha256", "candidate_unit_payload", "automated_prechecks", "review_requirements"],
        "properties": {
          "review_entry_id": {"type": "string", "pattern": "^M11_REVIEW_[0-9A-F]{20}$"},
          "grammar_unit_id": {"type": "string", "minLength": 1},
          "internal_stage": {"enum": ["A1", "A1+"]},
          "canonical_egp_row_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "candidate_payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "candidate_unit_payload": {"type": "object", "minProperties": 10},
          "automated_prechecks": {
            "type": "object",
            "additionalProperties": false,
            "required": ["overall_status", "checks"],
            "properties": {
              "overall_status": {"enum": ["PASS", "WARNING", "BLOCK"]},
              "checks": {"type": "object", "additionalProperties": {"type": "boolean"}}
            }
          },
          "review_requirements": {"type": "array", "minItems": 12, "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    },
    "review_entries_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claim_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["private_local_only", "canonical_authority_promotion", "public_delivery", "learner_mastery_claimed", "a2_a2plus_in_scope"],
      "properties": {
        "private_local_only": {"const": true},
        "canonical_authority_promotion": {"const": false},
        "public_delivery": {"const": false},
        "learner_mastery_claimed": {"const": false},
        "a2_a2plus_in_scope": {"const": false}
      }
    }
  }
}
