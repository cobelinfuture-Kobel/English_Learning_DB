{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/e4s_a1v1_m12e1_human_review_decisions.schema.json",
  "title": "M12E1 Private Human Review Decisions",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "schema_version", "private_local_only", "source_review_queue_sha256", "reviewer_id", "reviewed_at", "decisions"],
  "properties": {
    "task_id": {"const": "E4S-A1V1-M12E1_HumanReviewDecisionMaterialization"},
    "schema_version": {"const": "e4s.a1v1.m12e1.human_review_decisions.v1"},
    "private_local_only": {"const": true},
    "source_review_queue_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reviewer_id": {"type": ["string", "null"]},
    "reviewed_at": {"type": ["string", "null"]},
    "decisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 184,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item_id", "decision", "criteria", "notes"],
        "properties": {
          "item_id": {"type": "string", "minLength": 1},
          "decision": {"enum": ["PENDING", "APPROVE", "REJECT", "DEFER"]},
          "criteria": {
            "type": "object",
            "additionalProperties": false,
            "required": ["grammar_target_match", "meaning_matches_context", "complete_response"],
            "properties": {
              "grammar_target_match": {"type": ["boolean", "null"]},
              "meaning_matches_context": {"type": ["boolean", "null"]},
              "complete_response": {"type": ["boolean", "null"]}
            }
          },
          "notes": {"type": ["string", "null"]}
        }
      }
    }
  }
}
