{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/raz_ai_theme_sentence_scene_candidate_classification.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "schema_version",
    "validation_status",
    "source_scope",
    "authority_baselines",
    "theme_situation_candidates",
    "sentence_seed_candidates",
    "scene_seed_candidates",
    "cross_links",
    "classification_summary",
    "classification_gate",
    "claim_boundaries",
    "errors",
    "package_sha256"
  ],
  "properties": {
    "task_id": {"const": "RAZ-AI_ThemeSentenceSceneCandidateClassification"},
    "schema_version": {"const": "raz.ai.theme_sentence_scene_candidate_classification.v1"},
    "validation_status": {"const": "PASS_RAZ_AI_THEME_SENTENCE_SCENE_CANDIDATE_CLASSIFICATION"},
    "source_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["levels", "record_count", "book_count", "level_counts", "source_files", "j_w_read_performed"],
      "properties": {
        "levels": {"const": ["A", "B", "C", "D", "E", "F", "G", "H", "I"]},
        "record_count": {"type": "integer", "minimum": 1},
        "book_count": {"type": "integer", "minimum": 1},
        "level_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "source_files": {"type": "array", "minItems": 9, "maxItems": 9},
        "j_w_read_performed": {"const": false}
      }
    },
    "authority_baselines": {"type": "object", "required": ["vocabulary", "chunks", "patterns", "themes"]},
    "theme_situation_candidates": {
      "type": "array",
      "items": {"$ref": "#/$defs/themeSituation"}
    },
    "sentence_seed_candidates": {
      "type": "array",
      "items": {"$ref": "#/$defs/sentenceSeed"}
    },
    "scene_seed_candidates": {
      "type": "array",
      "items": {"$ref": "#/$defs/sceneSeed"}
    },
    "cross_links": {
      "type": "array",
      "items": {"$ref": "#/$defs/crossLink"}
    },
    "classification_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "theme_situation_candidate_count",
        "sentence_seed_candidate_count",
        "scene_seed_candidate_count",
        "cross_link_count",
        "sentence_maturity_counts",
        "scene_type_counts",
        "theme_disposition_counts",
        "sentence_duplicate_group_count",
        "scene_semantic_group_count"
      ],
      "properties": {
        "theme_situation_candidate_count": {"type": "integer", "minimum": 1},
        "sentence_seed_candidate_count": {"type": "integer", "minimum": 1},
        "scene_seed_candidate_count": {"type": "integer", "minimum": 1},
        "cross_link_count": {"type": "integer", "minimum": 1},
        "sentence_maturity_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "scene_type_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "theme_disposition_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "sentence_duplicate_group_count": {"type": "integer", "minimum": 1},
        "scene_semantic_group_count": {"type": "integer", "minimum": 1}
      }
    },
    "classification_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_checks",
        "decision",
        "ready_for_human_review",
        "ready_for_canonical_promotion",
        "ready_for_learning_unit_population",
        "next_short_step"
      ],
      "properties": {
        "source_checks": {"type": "object", "additionalProperties": {"type": "boolean"}},
        "decision": {"enum": ["CLASSIFICATION_READY_FOR_REVIEW", "BLOCKED_SOURCE_OR_ACCOUNTING_INTEGRITY"]},
        "ready_for_human_review": {"type": "boolean"},
        "ready_for_canonical_promotion": {"const": false},
        "ready_for_learning_unit_population": {"const": false},
        "next_short_step": {"type": "string", "minLength": 1}
      }
    },
    "claim_boundaries": {"type": "object"},
    "errors": {"type": "array", "maxItems": 0},
    "package_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "themeSituation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "theme_situation_candidate_id",
        "source_macro_domain",
        "canonical_theme_id",
        "situation_family",
        "micro_situation",
        "communicative_functions",
        "participant_roles",
        "interaction_goals",
        "source_ref_count",
        "source_book_count",
        "source_levels",
        "disposition",
        "promotion_status"
      ],
      "properties": {
        "theme_situation_candidate_id": {"type": "string", "pattern": "^TSIT_[0-9A-F]{16}$"},
        "source_macro_domain": {"type": "string", "minLength": 1},
        "canonical_theme_id": {"type": ["string", "null"]},
        "situation_family": {"type": "string", "minLength": 1},
        "micro_situation": {"type": "string", "minLength": 1},
        "communicative_functions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "participant_roles": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "interaction_goals": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "source_ref_count": {"type": "integer", "minimum": 1},
        "source_book_count": {"type": "integer", "minimum": 1},
        "source_levels": {"type": "array", "items": {"enum": ["A", "B", "C", "D", "E", "F", "G", "H", "I"]}, "uniqueItems": true},
        "disposition": {"enum": ["CANONICAL_THEME_MATCH", "CROSS_THEME_BRIDGE", "SITUATION_FAMILY_MATCH", "NEW_SITUATION_CANDIDATE", "HUMAN_REVIEW_REQUIRED"]},
        "promotion_status": {"const": "NOT_PROMOTED"}
      }
    },
    "sentenceSeed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sentence_seed_id",
        "source_unit_ref",
        "source_level",
        "source_band",
        "grammar_unit_candidates",
        "vocabulary_refs",
        "chunk_refs",
        "pattern_refs",
        "theme_situation_candidate_ids",
        "primary_communicative_function",
        "seed_maturity",
        "primary_material_role",
        "semantic_duplicate_group_id",
        "level_suitability_status",
        "promotion_status"
      ],
      "properties": {
        "sentence_seed_id": {"type": "string", "pattern": "^SSEED_[0-9A-F]{16}$"},
        "source_unit_ref": {"type": "string", "minLength": 1},
        "source_level": {"enum": ["A", "B", "C", "D", "E", "F", "G", "H", "I"]},
        "source_band": {"enum": ["AF", "GI"]},
        "grammar_unit_candidates": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "vocabulary_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "chunk_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "pattern_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "theme_situation_candidate_ids": {"type": "array", "items": {"type": "string", "pattern": "^TSIT_[0-9A-F]{16}$"}, "minItems": 1, "uniqueItems": true},
        "primary_communicative_function": {"type": "string", "minLength": 1},
        "seed_maturity": {"enum": ["STRICT_CORE_SENTENCE_SEED", "BROAD_CORE_SENTENCE_SEED", "DIALOGUE_TURN_SEED", "PASSAGE_ONLY_SEED", "SUPPORT_SENTENCE_SEED", "DEFERRED_OR_REJECTED"]},
        "primary_material_role": {"enum": ["MODEL_SENTENCE", "GUIDED_PRACTICE_SENTENCE", "DIALOGUE_TURN", "PASSAGE_SUPPORT_SENTENCE", "DEFERRED"]},
        "semantic_duplicate_group_id": {"type": "string", "pattern": "^SDUP_[0-9A-F]{16}$"},
        "level_suitability_status": {"const": "A1_A1PLUS_REVIEW_REQUIRED"},
        "promotion_status": {"const": "NOT_PROMOTED"}
      }
    },
    "sceneSeed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_seed_id",
        "source_unit_ref",
        "source_level",
        "source_band",
        "theme_situation_candidate_ids",
        "scene_type",
        "presentation_format",
        "pedagogical_uses",
        "semantic_scene_group_id",
        "visualizable_status",
        "target_visible_status",
        "answerability_status",
        "language_leakage_status",
        "scene_consistency_status",
        "age_appropriateness_status",
        "promotion_status"
      ],
      "properties": {
        "scene_seed_id": {"type": "string", "pattern": "^SCENE_[0-9A-F]{16}$"},
        "source_unit_ref": {"type": "string", "minLength": 1},
        "source_level": {"enum": ["A", "B", "C", "D", "E", "F", "G", "H", "I"]},
        "source_band": {"enum": ["AF", "GI"]},
        "theme_situation_candidate_ids": {"type": "array", "items": {"type": "string", "pattern": "^TSIT_[0-9A-F]{16}$"}, "minItems": 1, "uniqueItems": true},
        "scene_type": {"enum": ["OBJECT_IDENTIFICATION", "PERSON_OR_CHARACTER_DESCRIPTION", "ACTION_SCENE", "LOCATION_RELATION_SCENE", "SOCIAL_INTERACTION_SCENE", "ROUTINE_SCENE", "SEQUENCE_SCENE", "PROBLEM_ACTION_RESULT_SCENE", "CAUSE_EFFECT_SCENE", "COMPARISON_SCENE", "MAP_OR_ROUTE_SCENE", "SCIENTIFIC_OR_INFORMATIONAL_SCENE", "GENERAL_CONTEXT_SCENE"]},
        "presentation_format": {"enum": ["SINGLE_FRAME", "MULTI_PANEL_SEQUENCE", "DIALOGUE_FRAME", "MAP_OR_DIAGRAM", "OBJECT_GRID", "BEFORE_AFTER_PAIR"]},
        "pedagogical_uses": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
        "semantic_scene_group_id": {"type": "string", "pattern": "^SCGRP_[0-9A-F]{16}$"},
        "visualizable_status": {"enum": ["SUPPORTED", "REVIEW_REQUIRED"]},
        "target_visible_status": {"const": "CANDIDATE_REVIEW_REQUIRED"},
        "answerability_status": {"const": "CANDIDATE_REVIEW_REQUIRED"},
        "language_leakage_status": {"const": "NOT_ASSESSED"},
        "scene_consistency_status": {"const": "NOT_ASSESSED"},
        "age_appropriateness_status": {"const": "SOURCE_LEVEL_CANDIDATE"},
        "promotion_status": {"const": "NOT_PROMOTED"}
      }
    },
    "crossLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_unit_ref", "theme_situation_candidate_ids", "sentence_seed_id", "scene_seed_id"],
      "properties": {
        "source_unit_ref": {"type": "string", "minLength": 1},
        "theme_situation_candidate_ids": {"type": "array", "items": {"type": "string", "pattern": "^TSIT_[0-9A-F]{16}$"}, "minItems": 1, "uniqueItems": true},
        "sentence_seed_id": {"type": "string", "pattern": "^SSEED_[0-9A-F]{16}$"},
        "scene_seed_id": {"type": "string", "pattern": "^SCENE_[0-9A-F]{16}$"}
      }
    }
  }
}
