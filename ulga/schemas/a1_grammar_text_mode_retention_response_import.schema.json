{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "a1_grammar_text_mode_retention_response_import.schema.json",
  "title": "A1/A1+ Text-Mode Retention Response Import",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "retention_schema_version",
    "baseline_session_id",
    "grammar_unit_ids",
    "session",
    "responses"
  ],
  "properties": {
    "retention_schema_version": {
      "const": "a1_grammar_text_mode_retention_response_import.v1"
    },
    "baseline_session_id": {
      "type": "string",
      "minLength": 1
    },
    "grammar_unit_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "learner_ref",
        "operator_ref",
        "started_at",
        "completed_at",
        "evidence_source_ref"
      ],
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "learner_ref": {
          "type": "string",
          "minLength": 1
        },
        "operator_ref": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "evidence_source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "responses": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "response_text",
          "submitted_at"
        ],
        "properties": {
          "item_id": {
            "type": "string",
            "minLength": 1
          },
          "response_text": {
            "type": "string"
          },
          "submitted_at": {
            "type": "string",
            "format": "date-time"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "passed": {
            "type": "boolean"
          },
          "error_tags": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evaluator_type": {
            "enum": [
              "MANUAL",
              "HYBRID"
            ]
          },
          "evaluator_ref": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
